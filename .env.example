# HardRok.com — required environment variables
# Copy to .env for local dev; set in Netlify UI for deploys.

# --- Supabase (system of record for ALL leads) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Twilio (SMS flows, SPEC.md §9) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# TODO: confirm the published text-to-quote number (TODO.md Part 2E)

# --- Lead delivery (SPEC.md §8) ---
# Master switch. false (default) = pre-CRM email mode: leads are emailed to
# LEAD_EMAIL_TO (crm_status='email_sent'), like the old GoDaddy form — but the
# lead is ALWAYS saved to Supabase first, and rep SMS alerts fire in both
# modes. Flip to true once the CRM vendor is ready — no code change.
CRM_ENABLED=false

# Email mode (used when CRM_ENABLED=false)
# TODO: confirm the receiving inbox and a verified sender on a domain the
# client controls (deliverability), e.g. leads@hardrok.com / website@hardrok.com
LEAD_EMAIL_TO=
LEAD_EMAIL_FROM=
# One of: resend (default) | sendgrid | smtp (stub). Resend = least friction
# from a Netlify Function; SendGrid = Twilio-owned if keeping vendor count down.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
# SENDGRID_API_KEY=   # only when EMAIL_PROVIDER=sendgrid

# CRM mode (used when CRM_ENABLED=true; vendor unknown)
# One of: webhook | hubspot | zoho | pipedrive. Default: webhook.
CRM_PROVIDER=webhook
CRM_WEBHOOK_URL=
# TODO: set the matching adapter once the client names their CRM vendor

# --- Alerts ---
# Receives SMS when a lead's CRM sync fails (SPEC.md §8)
ADMIN_PHONE=

# --- Site ---
PUBLIC_SITE_URL=https://www.hardrok.com
