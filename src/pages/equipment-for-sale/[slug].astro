---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadForm from '@components/LeadForm.astro';
import { SITE } from '@lib/site';

export async function getStaticPaths() {
  const listings = await getCollection('equipment-for-sale', ({ data }) => !data.draft);
  return listings.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'equipment-for-sale'>;
}
const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

const path = `/equipment-for-sale/${entry.slug}/`;
const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Equipment for Sale', href: '/equipment-for-sale/' },
  { label: data.title, href: path },
];
---

<BaseLayout title={data.metaTitle} description={data.metaDescription} breadcrumbs={crumbs}>
  <article class="container-content section-pad">
    <p class="text-meta font-semibold uppercase tracking-heading text-steel">{data.category}</p>
    <h1 class="mt-1">{data.title}</h1>
    <p class="mt-3 text-body font-semibold">{data.price ?? 'Call for price'}</p>

    <div class="prose-measure mt-6 space-y-4 [&_p]:leading-relaxed">
      <Content />
    </div>

    <section class="mt-12 grid gap-10 lg:grid-cols-2">
      <LeadForm
        source="quote_form"
        sourcePage={path}
        compact
        prefillCategory="Equipment"
        heading="Ask about this machine"
      />
      <p class="text-steel">
        Or call <a href={SITE.phoneHref} class="font-semibold underline">{SITE.phone}</a> — {SITE.hours}.
      </p>
    </section>
  </article>
</BaseLayout>
