---
// Spanish contact page. TODO: native-speaker review by HardRok team.
import LayoutEs from '@layouts/LayoutEs.astro';
import LeadForm from '@components/LeadForm.astro';
import { SITE } from '@lib/site';
---

<LayoutEs
  title="Contacto | HardRok Equipment"
  description="Comuníquese con HardRok Equipment: piezas para trituradoras, mallas y transportadores. Llame al (866) 427-3765 o solicite su cotización en línea."
  englishHref="/contact/"
>
  <div class="container-content section-pad">
    <h1>Contacto — HardRok Equipment</h1>

    <div class="mt-8 grid items-start gap-10 lg:grid-cols-2">
      <div class="space-y-6">
        <section class="card p-6">
          <h2 class="text-h3">Llámenos</h2>
          <p class="mt-2">
            <a href={SITE.phoneHref} class="font-heading text-h3 font-bold text-ink underline">
              {SITE.phone}
            </a>
          </p>
          <p class="mt-1 text-steel">Lun–Vie 7am–5pm PST</p>
        </section>
        <section class="card p-6">
          <h2 class="text-h3">Oficinas</h2>
          <p class="mt-2 text-steel">Corporativo: Winnemucca, Nevada</p>
          <p class="mt-1 text-steel">Oficina de California: Galt, CA</p>
        </section>
      </div>

      <LeadForm source="quote_form" sourcePage="/es/contacto/" locale="es" />
    </div>
  </div>
</LayoutEs>
