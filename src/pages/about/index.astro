---
import BaseLayout from '@layouts/BaseLayout.astro';
import TodoBadge from '@components/TodoBadge.astro';
import CTAButton from '@components/CTAButton.astro';
import { SITE } from '@lib/site';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
];
---

<BaseLayout
  title="About HardRok Equipment | Aggregate & Mining Parts"
  description="HardRok Equipment supplies aftermarket crusher, conveyor & screening parts to mining and aggregate producers across the western U.S. Learn our story."
  breadcrumbs={crumbs}
>
  <article class="container-content section-pad">
    <h1>40 Years Keeping Crushing Operations Running</h1>

    <div class="prose-measure mt-6 space-y-4">
      <p>
        HardRok Equipment was built by people who have stood in the pit at 3am with a crusher
        down. We supply the wear parts, screen media, and conveyor components that keep aggregate
        and hard-rock mining operations producing — backed by technical knowledge most parts
        suppliers can't offer.
      </p>
      {/* Founding story sourced from the existing site's About page (indexed copy, 2026-07) */}
      <p>
        HardRok Equipment was established by Ted Zebroski to serve Nevada's industrial mineral
        and aggregate industries. After years as a maintenance supervisor, Ted built HardRok
        around a simple proposition: exceptional value through quality products and service.
        Headquartered in Winnemucca, Nevada, HardRok has also served California producers since
        1999 — and the reputation is still built the same way, on service and technical support.
      </p>
      {/* Leadership confirmed from the site's own contact page (2026-07-23) */}
      <h2 class="mt-8 text-h3">Leadership</h2>
      <ul class="list-disc space-y-1 pl-5 text-steel">
        <li><strong class="text-ink">Theodore "Ted" Zebroski</strong> — President/CEO &amp; founder</li>
        <li><strong class="text-ink">Eric Dutton</strong> — Vice President</li>
        <li><strong class="text-ink">Justin Kroeck</strong> — California Operations Manager</li>
      </ul>
      <p class="text-steel">
        Offices in Winnemucca, Nevada (corporate) and Galt, California (office &amp; warehouse).
        <TodoBadge label="TODO: exact founding year" />
        <TodoBadge label="TODO: team size" />
      </p>
      <p>
        What we can tell you now: we've spent over 40 years supplying crushing, conveying, and
        screening operations; we answer the phone {SITE.hours}; and we're an authorized
        <a href="/brands/cms-cepcor/" class="underline">CMS Cepcor dealer</a> alongside our own
        <a href="/products/battleborn-wear-products/" class="underline">Battleborn™</a> wear line.
      </p>
    </div>

    <div class="mt-8 flex flex-wrap gap-4">
      <CTAButton href="/team/">Meet the team</CTAButton>
      <CTAButton href="/quote/" variant="secondary">Request a quote</CTAButton>
    </div>
  </article>
</BaseLayout>
