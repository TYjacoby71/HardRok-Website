---
// Service-area template (SPEC §5.5): TerritoryMap highlighted, assigned
// RepCard, shipping notes, local industries, territory-tagged LeadForm,
// areaServed schema. New markdown file => complete page, no code changes.
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import TerritoryMap from '@components/TerritoryMap.astro';
import RepCard from '@components/RepCard.astro';
import LeadForm from '@components/LeadForm.astro';
import TodoBadge from '@components/TodoBadge.astro';
import { serviceAreaSchema } from '@lib/schema';
import { SITE } from '@lib/site';

export async function getStaticPaths() {
  const areas = await getCollection('service-areas');
  return areas.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'service-areas'>;
}
const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

const rep = data.repSlug ? await getEntry('team', data.repSlug) : undefined;

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/service-areas/' },
  { label: data.state, href: `/service-areas/${entry.slug}/` },
];
const path = `/service-areas/${entry.slug}/`;
---

<BaseLayout
  title={data.metaTitle}
  description={data.metaDescription}
  breadcrumbs={crumbs}
  schemas={[serviceAreaSchema({ state: data.state, url: path })]}
>
  <article class="container-content section-pad">
    <h1>{data.title}</h1>

    <div class="mt-8 grid items-start gap-10 lg:grid-cols-2">
      <div>
        <div class="prose-measure space-y-4 [&_p]:leading-relaxed">
          <Content />
        </div>

        <section class="mt-8">
          <h2 class="mb-3 text-h3">Shipping &amp; delivery in {data.state}</h2>
          <p class="text-steel">
            {
              data.shippingNotesTodo && (
                <>
                  <TodoBadge label="TODO: regional delivery notes" /> Regional shipping and
                  delivery details are being confirmed. Call{' '}
                  <a href={SITE.phoneHref} class="font-semibold underline">
                    {SITE.phone}
                  </a>{' '}
                  for current lead times to your site.
                </>
              )
            }
          </p>
        </section>

        {
          data.localIndustries.length > 0 && (
            <section class="mt-8">
              <h2 class="mb-3 text-h3">Industries we serve in {data.state}</h2>
              <ul class="flex flex-wrap gap-3">
                {data.localIndustries.map((ind) => (
                  <li>
                    <a
                      href={ind.href}
                      class="inline-block rounded border border-steel/40 bg-white px-4 py-2 text-nav font-medium text-ink no-underline hover:border-ink"
                    >
                      {ind.label}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </div>

      <TerritoryMap highlight={data.abbr} showList={false} />
    </div>

    <section class="mt-12">
      <h2 class="mb-4">Your {data.state} rep</h2>
      {
        rep ? (
          <div class="max-w-md">
            <RepCard rep={rep} />
          </div>
        ) : (
          <p class="max-w-xl text-steel">
            <TodoBadge label="TODO: assign territory rep" /> A dedicated rep for {data.state} is
            being confirmed. Meanwhile, our inside sales team covers the state directly — call{' '}
            <a href={SITE.phoneHref} class="font-semibold underline">
              {SITE.phone}
            </a>{' '}
            and you'll be helped immediately.
          </p>
        )
      }
    </section>

    <section class="mt-12 max-w-xl">
      <LeadForm
        source="quote_form"
        sourcePage={path}
        territory={data.abbr}
        heading={`Request a quote in ${data.state}`}
      />
    </section>
  </article>
</BaseLayout>
