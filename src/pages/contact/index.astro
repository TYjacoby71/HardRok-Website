---
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadForm from '@components/LeadForm.astro';
import TodoBadge from '@components/TodoBadge.astro';
import { SITE } from '@lib/site';

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Contact', href: '/contact/' },
];
---

<BaseLayout
  title="Contact Us | HardRok Equipment"
  description="Reach HardRok Equipment for crusher parts, screen media & conveyor components. Call (866) 427-3765, text a photo of your part, or request a quote online."
  breadcrumbs={crumbs}
  alternates={[
    { hreflang: 'en', href: '/contact/' },
    { hreflang: 'es', href: '/es/contacto/' },
    { hreflang: 'x-default', href: '/contact/' },
  ]}
>
  <div class="container-content section-pad">
    <h1>Contact HardRok Equipment</h1>

    <div class="mt-8 grid items-start gap-10 lg:grid-cols-2">
      <div class="space-y-6">
        <section class="card p-6">
          <h2 class="text-h3">Call</h2>
          <p class="mt-2">
            <a href={SITE.phoneHref} class="text-h3 font-heading font-bold text-ink underline">
              {SITE.phone}
            </a>
          </p>
          <p class="mt-1 text-steel">{SITE.phoneVanity} · {SITE.hours}</p>
        </section>

        <section class="card p-6" id="text-to-quote">
          <h2 class="text-h3">Text a photo of your part</h2>
          <p class="mt-2 text-steel">
            {
              SITE.textQuoteNumber ? (
                <>
                  Text{' '}
                  <a
                    href={`sms:${SITE.textQuoteNumber.replace(/[^+\d]/g, '')}`}
                    class="font-semibold underline"
                  >
                    {SITE.textQuoteNumber}
                  </a>{' '}
                  with a photo of the worn part and your machine model.
                </>
              ) : (
                <>
                  Text-to-quote is being set up <TodoBadge label="TODO: Twilio number" /> — attach
                  a photo via the quote form meanwhile.
                </>
              )
            }
          </p>
        </section>

        {/* Offices + leadership confirmed from the site's own contact page (2026-07-23) */}
        <section class="card p-6">
          <h2 class="text-h3">Offices</h2>
          <address class="mt-2 space-y-4 not-italic text-steel">
            <p>
              <strong class="text-ink">Corporate Office</strong><br />
              HardRok Equipment Inc.<br />
              P.O. Box 295, Winnemucca, NV 89445<br />
              Phone: <a href="tel:+17756253101" class="underline">(775) 625-3101</a> · Fax: (775) 625-3141
            </p>
            <p>
              <strong class="text-ink">California Office &amp; Warehouse</strong><br />
              85 Enterprise Court, Suite A, Galt, CA 95632<br />
              Phone: <a href="tel:+12097452204" class="underline">(209) 745-2204</a> · Warehouse:
              <a href="tel:+12097452209" class="underline">(209) 745-2209</a>
            </p>
          </address>
        </section>

        <section class="card p-6">
          <h2 class="text-h3">Leadership</h2>
          <ul class="mt-2 space-y-3 text-steel">
            <li>
              <strong class="text-ink">Theodore Zebroski</strong> — President/CEO ·
              <a href="mailto:taz@hardrok.com" class="underline">taz@hardrok.com</a>
            </li>
            <li>
              <strong class="text-ink">Eric Dutton</strong> — Vice President ·
              <a href="mailto:eric@hardrok.com" class="underline">eric@hardrok.com</a>
            </li>
            <li>
              <strong class="text-ink">Justin Kroeck</strong> — CA Operations Manager ·
              <a href="mailto:justin.k@hardrok.com" class="underline">justin.k@hardrok.com</a>
            </li>
          </ul>
        </section>
      </div>

      <LeadForm source="quote_form" sourcePage="/contact/" />
    </div>
  </div>
</BaseLayout>
