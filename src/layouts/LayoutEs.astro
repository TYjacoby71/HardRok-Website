---
// Spanish conversion-path layout: slim header (logo, phone, English toggle),
// Spanish sticky mobile bar, slim Spanish footer. Full-site Spanish mirroring
// can follow; this covers the conversion path first.
// TODO: Spanish copy pending native-speaker review by HardRok's team.
import '@fontsource/barlow-condensed/600.css';
import '@fontsource/barlow-condensed/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '../styles/global.css';
import { organizationSchema, localBusinessSchema } from '@lib/schema';
import { SITE } from '@lib/site';

interface Props {
  title: string;
  description: string;
  englishHref: string; // EN counterpart for hreflang + toggle
  noindex?: boolean;
}
const { title, description, englishHref, noindex = false } = Astro.props;
const path = Astro.url.pathname;
const canonical = `${SITE.origin}${path}`;

const esLinks = [
  { label: 'Inicio', href: '/es/' },
  { label: 'Cotización', href: '/es/cotizacion/' },
  { label: 'Contacto', href: '/es/contacto/' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={`${SITE.origin}${englishHref}`} />
    <link rel="alternate" hreflang="es" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={`${SITE.origin}${englishHref}`} />
    <meta
      name="robots"
      content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'}
    />
    <meta name="theme-color" content="#1A1D21" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE.origin}/images/og-default.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema())} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema())} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50 focus:rounded focus:bg-safety focus:px-4 focus:py-2 focus:font-semibold focus:text-ink"
    >
      Saltar al contenido
    </a>
    <header class="sticky top-0 z-40 border-b border-card bg-white py-2 shadow-sm">
      <div class="container-content flex items-center justify-between gap-4">
        <a href="/es/" class="flex items-baseline gap-1.5 no-underline" aria-label="HardRok Equipment — inicio">
          <span class="font-heading text-3xl font-bold uppercase tracking-heading text-ink">HardRok</span>
          <span class="font-heading text-xl font-semibold uppercase tracking-heading text-steel">Equipment</span>
        </a>
        <nav aria-label="Principal" class="hidden items-center gap-5 md:flex">
          {
            esLinks.map((l) => (
              <a href={l.href} class="text-nav font-medium text-steel no-underline hover:text-ink">
                {l.label}
              </a>
            ))
          }
        </nav>
        <div class="flex items-center gap-4">
          <a href={SITE.phoneHref} class="hidden text-nav font-semibold text-ink no-underline hover:underline sm:block">
            {SITE.phone}
          </a>
          <a
            href={englishHref}
            class="rounded border border-steel/40 px-3 py-1.5 text-nav font-medium text-steel no-underline hover:border-ink hover:text-ink"
            lang="en"
          >
            English
          </a>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="bg-ink pb-24 pt-10 text-white md:pb-10">
      <div class="container-content space-y-3 text-meta text-white/75">
        <p class="font-heading text-h4 font-semibold uppercase tracking-heading text-white">
          HardRok Equipment
        </p>
        <p>
          <a href={SITE.phoneHref} class="font-semibold text-white no-underline hover:underline">{SITE.phone}</a>
          · Lun–Vie 7am–5pm PST · {SITE.addressLocality}, {SITE.addressRegion}
        </p>
        <nav aria-label="Pie de página" class="flex flex-wrap gap-4">
          {
            esLinks.map((l) => (
              <a href={l.href} class="text-white/75 underline hover:text-white">
                {l.label}
              </a>
            ))
          }
          <a href="/" class="text-white/75 underline hover:text-white" lang="en">
            Sitio completo en inglés
          </a>
        </nav>
        <p>&copy; {new Date().getFullYear()} {SITE.legalName} Todos los derechos reservados.</p>
      </div>
    </footer>

    <nav
      aria-label="Contacto rápido"
      class="fixed inset-x-0 bottom-0 z-40 grid grid-cols-3 border-t border-card bg-white shadow-[0_-2px_8px_rgba(26,29,33,0.12)] md:hidden"
    >
      <a href={SITE.phoneHref} class="py-3.5 text-center text-nav font-semibold text-ink no-underline">
        Llamar
      </a>
      <a
        href={SITE.textQuoteNumber ? `sms:${SITE.textQuoteNumber.replace(/[^+\d]/g, '')}` : '/es/contacto/'}
        class="border-x border-card py-3.5 text-center text-nav font-semibold text-ink no-underline"
      >
        Texto
      </a>
      <a href="/es/cotizacion/" class="bg-safety py-3.5 text-center text-nav font-bold text-ink no-underline">
        Cotizar
      </a>
    </nav>
  </body>
</html>
