---
import '@fontsource/barlow-condensed/600.css';
import '@fontsource/barlow-condensed/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '../styles/global.css';
import Header from '@components/Header.astro';
import FooterMega from '@components/FooterMega.astro';
import StickyMobileCTA from '@components/StickyMobileCTA.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { organizationSchema, localBusinessSchema } from '@lib/schema';
import { SITE } from '@lib/site';

interface Props {
  title: string; // unique, <= 60 chars, "{Keyword} | HardRok Equipment"
  description: string; // unique, <= 155 chars
  breadcrumbs?: { label: string; href: string }[];
  noindex?: boolean;
  ogType?: 'website' | 'article';
  schemas?: Record<string, unknown>[]; // page-specific JSON-LD
  // hreflang pairs for pages with a Spanish counterpart
  alternates?: { hreflang: string; href: string }[];
}
const {
  title,
  description,
  breadcrumbs,
  noindex = false,
  ogType = 'website',
  schemas = [],
  alternates = [],
} = Astro.props;

const path = Astro.url.pathname;
const canonical = `${SITE.origin}${path}`;
const jsonLd = [organizationSchema(), localBusinessSchema(), ...schemas];
const gaId = import.meta.env.PUBLIC_GA4_ID as string | undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={`${SITE.origin}${alt.href}`} />
      ))
    }
    <meta
      name="robots"
      content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'}
    />
    <meta name="theme-color" content="#1A1D21" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {/* TODO: replace with branded photography raster once assets arrive (TODO.md Part 2F) */}
    <meta property="og:image" content={`${SITE.origin}/images/og-default.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="HardRok Equipment — crusher, conveyor and screening parts" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE.origin}/images/og-default.png`} />

    {jsonLd.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}

    {/* Analytics: renders ONLY when PUBLIC_GA4_ID is set (build-time env). */}
    {
      gaId && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
          />
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50 focus:rounded focus:bg-safety focus:px-4 focus:py-2 focus:font-semibold focus:text-ink"
    >
      Skip to content
    </a>
    <Header />
    {breadcrumbs && breadcrumbs.length > 1 && <Breadcrumbs items={breadcrumbs} />}
    <main id="main">
      <slot />
    </main>
    <FooterMega />
    <StickyMobileCTA />
  </body>
</html>
