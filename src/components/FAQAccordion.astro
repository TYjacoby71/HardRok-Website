---
// details/summary needs no JS and is keyboard-accessible; emits FAQPage schema.
import { faqSchema } from '@lib/schema';

interface Props {
  items: { q: string; a: string }[];
  heading?: string;
}
const { items, heading = 'Frequently Asked Questions' } = Astro.props;
const schema = JSON.stringify(faqSchema(items));
---

<section class="prose-measure">
  <h2 class="mb-6">{heading}</h2>
  <div class="divide-y divide-card border-y border-card">
    {
      items.map((item) => (
        <details class="group py-4">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-body text-body font-semibold">
            {item.q}
            <span
              aria-hidden="true"
              class="text-h3 leading-none text-steel transition-transform group-open:rotate-45"
            >
              +
            </span>
          </summary>
          <p class="mt-3 text-steel">{item.a}</p>
        </details>
      ))
    }
  </div>
</section>
<script type="application/ld+json" set:html={schema} />
