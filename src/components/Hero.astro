---
// Real photography from HardRok's own site archive (2026-07-23): Symons cone
// assemblies in the Galt, CA yard. Explicit dimensions keep CLS = 0.
interface Props {
  title: string;
  subhead?: string;
  eyebrow?: string;
}
const { title, subhead, eyebrow } = Astro.props;
---

<section class="relative overflow-hidden bg-ink text-white">
  <img
    src="/images/hardrok-yard-symons-cone-assemblies.webp"
    alt=""
    width="1600"
    height="640"
    class="absolute inset-0 h-full w-full object-cover opacity-40"
    fetchpriority="high"
  />
  <div class="container-content relative section-pad">
    {
      eyebrow && (
        <p class="mb-3 text-meta font-semibold uppercase tracking-heading text-safety">{eyebrow}</p>
      )
    }
    <h1 class="max-w-4xl text-white">{title}</h1>
    {subhead && <p class="prose-measure mt-5 text-body text-white/85">{subhead}</p>}
    <div class="mt-8 flex flex-wrap gap-4">
      <slot name="cta" />
    </div>
  </div>
</section>
