---
import { breadcrumbSchema } from '@lib/schema';

interface Props {
  items: { label: string; href: string }[];
}
const { items } = Astro.props;
const schema = JSON.stringify(breadcrumbSchema(items));
---

<nav aria-label="Breadcrumb" class="container-content py-3 text-meta text-steel">
  <ol class="flex flex-wrap items-center gap-1">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && <span aria-hidden="true">/</span>}
          {i === items.length - 1 ? (
            <span aria-current="page" class="font-medium text-ink">
              {item.label}
            </span>
          ) : (
            <a href={item.href} class="underline hover:text-ink">
              {item.label}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>
<script type="application/ld+json" set:html={schema} />
